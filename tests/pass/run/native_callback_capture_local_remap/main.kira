class Frame {
    let value: Int
}

@Native
function register(handler: (Frame) -> Void) {
    handler(Frame(2))
    return
}

@Native
function build(root: Int) {
    let frame = Frame(5)
    print(frame.value)
    print(root + 4)
    return
}

@Main
@Native
function main() {
    let rootId = 5
    register { frame in
        let returned = Frame(frame.value + 1)
        print(returned.value)
        build(rootId)
    }
    return
}
