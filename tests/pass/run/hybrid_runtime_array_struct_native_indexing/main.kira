@Runtime
struct RuntimeNested {
    var x: Int
    var y: Int
}

@Runtime
struct RuntimeItem {
    var x: Int
    var nested: RuntimeNested
}

@Runtime
function makeRuntimeItems() -> [RuntimeItem] {
    return [
        RuntimeItem { x: 11, nested: RuntimeNested { x: 101, y: 1001 } },
        RuntimeItem { x: 22, nested: RuntimeNested { x: 202, y: 2002 } },
        RuntimeItem { x: 33, nested: RuntimeNested { x: 303, y: 3003 } }
    ]
}

@Native
function nativeScore(items: [RuntimeItem], i: Int) -> Int {
    let item = items[i]
    let nested = items[i].nested
    return items[i].x + items[i].nested.x + item.x + nested.y + items[0].nested.x + items[2].x
}

@Native
function nativeMutate(items: [RuntimeItem], i: Int) {
    items[i].x = 55
    items[i].nested.x = 707
    return
}

@Runtime
function runtimeScore(items: [RuntimeItem], i: Int) -> Int {
    let item = items[i]
    let nested = items[i].nested
    return items[i].x + items[i].nested.x + item.x + nested.y + items[0].nested.x + items[2].x
}

@Main
@Runtime
function main() {
    let items = makeRuntimeItems()
    print(runtimeScore(items, 1))
    print(nativeScore(items, 1))
    nativeMutate(items, 1)
    print(items[1].x + items[1].nested.x)
    return
}
