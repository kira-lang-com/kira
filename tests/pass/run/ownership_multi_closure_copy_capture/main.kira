// Regression: a single Copy-typed local captured by-value into several closures
// declared in the same scope. Each `.copy` capture reads the value into its own
// closure environment without consuming the source, so one local may feed any
// number of callbacks. This is the foundation of the callback-driven UI event
// model (one shared state handle wired into onPress / onTextInput / onScroll on
// the same widget). Previously the Mid-IR checker treated `.copy` captures as
// moves, so the second closure reported KIR002 "place is moved or dropped".

function callTwice(first: () -> Int, second: () -> Int) {
    print(first())
    print(second())
    return
}

@Main
function main() {
    let seed = 4
    let adder: () -> Int = { in
        return seed + 1
    }
    let multiplier: () -> Int = { in
        return seed * 10
    }
    // `seed` remains usable after both captures because each capture copied it.
    let direct = seed + 0
    callTwice(move adder, move multiplier)
    print(direct)
    return
}
