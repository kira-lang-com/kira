// Regression: a call expression that ends a control-flow condition must not
// swallow the block-opening `{` as a trailing builder/callback block. Before the
// fix, `if k == syllable(...) {` parsed `syllable(...) { ... }` as a trailing
// block call and reported KPAR002/KPAR001. Conditions that end in a call, and
// nested trailing-block calls inside argument lists, must both parse correctly.

function syllable(a: Int, b: Int) -> Int {
    return a * 27 + b
}

function apply(cb: () -> Int) -> Int {
    return cb()
}

@Main
function main() {
    let key = syllable(14, 9)

    // Call ends the `if` condition.
    if key == syllable(14, 9) {
        print(1)
    }

    // Call is the whole `while` condition operand.
    var n = 0
    while n == syllable(0, 0) {
        print(2)
        n = 1
    }

    // Bare boolean-returning call directly before the block.
    if isPositive(key) {
        print(3)
    }

    // A trailing-callback call nested inside an argument list, itself inside a
    // condition, still parses because parens re-open the trailing-block context.
    if apply({ in return 5 }) == 5 {
        print(4)
    }
    return
}

function isPositive(value: Int) -> Bool {
    return value > 0
}
