// A concrete construct-backed declaration value coerces to `some Family`, and a heterogeneous
// array of different declarations of the same family unifies to `[some Family]` — the basis for
// caller-provided widget children. Executes identically on vm, llvm, and hybrid.

construct Widget {
}

Widget Text {
    let text: String = ""
}

Widget Spacer {
}

@Main
function main() {
    let single: some Widget = Text(text: "one")
    let items: [some Widget] = [Text(text: "a"), Spacer(), Text(text: "b")]
    print(items.count)
    return
}
