// Regression: mutations through a `borrow mut` struct parameter must write back
// to the caller across all backends. Covers scalar fields and array-element
// fields (both scalar- and struct-valued). The VM previously lost writes to an
// array element of a borrow-mut struct (`t.nodes[0].field = ...`) while LLVM did
// not — a backend parity violation that collapsed all UI layout to the origin,
// since the KiraLayout engine writes `tree.nodes[i].measuredSize`.

struct Pair { var w: Int = 0; var h: Int = 0 }
struct Node { var v: Int = 0; var sz: Pair = Pair {} }
struct Tree { var nodes: [Node] = [] }

function mutScalar(s: borrow mut Pair) {
    s.w = 111
    return
}

function mutElemScalar(t: borrow mut Tree) {
    t.nodes[0].v = 222
    return
}

function mutElemStruct(t: borrow mut Tree) {
    t.nodes[0].sz = Pair { w: 333, h: 444 }
    return
}

@Main
function main() {
    var p = Pair { w: 0, h: 0 }
    mutScalar(p)
    print(p.w)

    var a = Tree { nodes: [Node { v: 0, sz: Pair {} }] }
    mutElemScalar(a)
    print(a.nodes[0].v)

    var b = Tree { nodes: [Node { v: 0, sz: Pair {} }] }
    mutElemStruct(b)
    print(b.nodes[0].sz.w)
    return
}
