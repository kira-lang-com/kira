struct Pair {
    var left: I64
    var right: I64
}

struct State {
    var first: Pair
    var second: Pair
    var total: I64
}

@Main
function main() {
    var seed: Pair = Pair(4, 8)
    var state: State = State(seed, Pair(1, 2), 0)

    seed.left = seed.left + 3
    state.first.right = state.first.right + seed.left
    state.second = seed
    state.total = state.first.left + state.first.right

    print(seed.left)
    print(state.first.left)
    print(state.first.right)
    print(state.second.left)
    print(state.second.right)
    print(state.total)
    return
}
