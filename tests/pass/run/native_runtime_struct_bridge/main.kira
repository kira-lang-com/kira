@Runtime
struct Counter {
    var count: Int
}

@Runtime
function makeCounter(start: Int) -> Counter {
    var counter = Counter { count: start }
    counter.count = counter.count + 2
    return counter
}

@Native
function readAndBump(counter: Counter) -> Int {
    var next = counter
    next.count = next.count + 5
    return next.count
}

@Main
@Native
function main() {
    var counter = makeCounter(3)
    print(counter.count)
    counter.count = counter.count + 7
    print(counter.count)
    print(readAndBump(counter))
    return
}
