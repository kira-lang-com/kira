// Regression: `arr[i].xs.append(v)` left the nested array's count at 0 on
// VM/hybrid (append grew a transient element copy that was discarded). A later
// index then aborted out-of-bounds. The element must be written back.
struct Row {
    var xs: [Int]
}

@Main
function main() {
    var arr: [Row] = []
    arr.append(Row { xs: [] })
    arr[0].xs.append(42)
    arr[0].xs.append(43)
    print(arr[0].xs.count)
    print(arr[0].xs[0])
    print(arr[0].xs[1])
    return
}
