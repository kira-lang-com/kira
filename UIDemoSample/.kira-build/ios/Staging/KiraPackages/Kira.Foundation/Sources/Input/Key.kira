@Doc("Portable logical key identifier.
This small key set is enough for initial widget interaction and focus traversal.
Additional keys can be added later without changing the overall input model.")
enum Key {
    @Doc("Return or enter key.")
    Enter
    @Doc("Escape key.")
    Escape
    @Doc("Space bar.")
    Space
    @Doc("Left arrow key.")
    Left
    @Doc("Right arrow key.")
    Right
    @Doc("Up arrow key.")
    Up
    @Doc("Down arrow key.")
    Down
    @Doc("Tab key.")
    Tab
}
