@Doc("Minimal description used to create a texture resource.
The first graphics slice currently exposes only a debug label.
Additional size, format, and usage fields can expand here without changing the creation pattern.")
type TextureDescriptor {
    @Doc("Optional debug label associated with the created texture.
    Use short, stable names to improve GPU capture readability.
    Defaults to the empty string when the texture is unnamed.")
    var label: String = ""
}
