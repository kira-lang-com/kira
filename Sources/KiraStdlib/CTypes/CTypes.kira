@Doc("C interop primitive types.")
type CVoid { }

type CInt8  { var value: Int8 }
type CInt16 { var value: Int16 }
type CInt32 { var value: Int32 }
type CInt64 { var value: Int64 }

type CUInt8  { var value: UInt8 }
type CUInt16 { var value: UInt16 }
type CUInt32 { var value: UInt32 }
type CUInt64 { var value: UInt64 }

type CFloat  { var value: Float }
type CDouble { var value: Double }
type CBool   { var value: Bool }

