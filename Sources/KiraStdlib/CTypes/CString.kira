@Doc("Wrapper around a null-terminated C string pointer.
Use `CString` when an API wants explicit typing beyond a raw pointer.
The wrapper keeps interop call sites clearer than passing `CPointer<CInt8>` directly.")
type CString {
    @Doc("Pointer to the first byte of the null-terminated string buffer.
    The pointed-to memory must remain valid for the duration of the native call that consumes it.
    No ownership or lifetime management is enforced by this wrapper.")
    var pointer: CPointer<CInt8>
}
