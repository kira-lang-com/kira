@Doc("Helpers for working with success-or-failure style results.
This module is intentionally tiny while the stdlib result model is still evolving.
Use it as a stable place for lightweight predicates and adapters.")
type ResultHelpers {
    @Doc("Return whether a boolean success flag represents success.
    This helper is intentionally minimal and acts as a placeholder for richer result utilities.
    It keeps early examples readable while the broader result API grows.")
    function isSuccess(flag: Bool) -> Bool { return flag }
}
