        return a * b
    }
    // 1111111101
    expect { let e: Result<Int, TestFailure> = Result.Ok(1111111101); return e }
}

Test CfxSLargeDiv2 {
    test {
        let a = 1000000000000
        let b = 1000000
        return a / b
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1000000); return e }
