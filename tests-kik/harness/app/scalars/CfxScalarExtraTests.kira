// ---------------------------------------------------------------------------
// GCD cross-checks
// ---------------------------------------------------------------------------

Test CfxSGcdIdentity {
    test { return cfxsGcd(42, 42) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(42); return e }
}

Test CfxSGcdWithOne {
    test { return cfxsGcd(1, 999) }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test CfxSGcdSymmetric {
    test {
        let g1 = cfxsGcd(48, 18)
        let g2 = cfxsGcd(18, 48)
        return g1 == g2 ? 1 : 0
    }
    expect { let e: Result<Int, TestFailure> = Result.Ok(1); return e }
}

Test CfxSGcdChain {
    test {
        var g = cfxsGcd(360, 240)
        g = cfxsGcd(g, 180)
        g = cfxsGcd(g, 120)
        return g
    }
    // gcd(360,240)=120, gcd(120,180)=60, gcd(60,120)=60
    expect { let e: Result<Int, TestFailure> = Result.Ok(60); return e }
}

Test CfxSGcdLcmProduct {
    test {
        let a = 12
        let b = 18
        let g = cfxsGcd(a, b)
        let lcm = a * b / g
        return lcm
    }
    // gcd(12,18)=6, lcm=36
    expect { let e: Result<Int, TestFailure> = Result.Ok(36); return e }
}

