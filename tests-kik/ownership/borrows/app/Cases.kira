struct Counter {
    let value: Int = 0
}

function read(counter: borrow Counter) -> Int {
    return counter.value
}

Test BorrowOkResult {
    test {
        let counter = Counter {
            value: 42
        }
        return read(counter)
    }

    expect {
        let expected: Result<Int, TestFailure> = Result.Ok(42)
        return expected
    }
}
