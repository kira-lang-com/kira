function invoke(callback: borrow () -> Void) -> Int {
    callback()
    return 42
}

function marker() {
    return
}

Test ClosureBorrowOkResult {
    test {
        let callback: () -> Void = marker
        return invoke(callback)
    }

    expect {
        let expected: Result<Int, TestFailure> = Result.Ok(42)
        return expected
    }
}
