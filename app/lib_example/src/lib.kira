// Math utility library

@Native
func square(x: int) -> int {
    return x * x;
}

@Native
func cube(x: int) -> int {
    return x * x * x;
}

func factorial(n: int) -> int {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

func fibonacci(n: int) -> int {
    if n <= 1 {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}
