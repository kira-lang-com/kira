import math_utils;

func main() {
    let x: int = 5;
    let squared: int = math_utils.square(x);
    let cubed: int = math_utils.cube(x);
    
    printIn("Number: ");
    printIn(x);
    printIn("Squared: ");
    printIn(squared);
    printIn("Cubed: ");
    printIn(cubed);
    
    let fact: int = math_utils.factorial(x);
    printIn("Factorial: ");
    printIn(fact);
}
