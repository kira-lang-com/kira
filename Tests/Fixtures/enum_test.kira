enum Direction {
    North
    South
    East
    West
}

enum Shape {
    Circle(radius: Float)
    Point
}

function main() {
    let dir = Direction.North
    let shape = Shape.Circle(radius: 5.0)

    match dir {
        North: print("North")
        South: print("South")
        East: print("East")
        West: print("West")
    }

    match shape {
        Circle(let radius):
            if radius == 5.0 {
                print("Circle radius=5.0")
            } else {
                print("Circle radius=unexpected")
            }
        Point:
            print("Point")
    }

    return
}
