type Rectangle {
    var width: Float
    var height: Float

    function area() -> Float {
        return width * height
    }

    function scale(factor: Float) -> Rectangle {
        return Rectangle(width: width * factor, height: height * factor)
    }

    static function unit() -> Rectangle {
        return Rectangle(width: 1.0, height: 1.0)
    }
}

function main() {
    let rect = Rectangle(width: 10.0, height: 5.0)
    let area = rect.area()
    let scaled = rect.scale(factor: 2.0)
    let unit = Rectangle.unit()

    if area == 50.0 {
        print("area=50.0")
    } else {
        print("area=unexpected")
    }

    if scaled.width == 20.0 && unit.width == 1.0 {
        print("scaled width=20.0")
    } else {
        print("scaled width=unexpected")
    }

    return
}
