import Kira.Graphics

type EmptyScene: Scene {
    function onLoad(device: GraphicsDevice) {
        return
    }

    function onFrame(frame: Frame) {
        return
    }

    function onResize(width: Int, height: Int) {
        return
    }

    function onUnload() {
        return
    }
}

function main() {
    let app = Application() {
        title = "Test"
        width = 800
        height = 600
    }
    let scene = EmptyScene()
    print(app.title)
    print(scene)
    return
}
