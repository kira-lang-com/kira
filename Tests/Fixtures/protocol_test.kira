protocol Drawable {
    function draw() -> Void
    function boundsX() -> Float
}

type Circle: Drawable {
    var radius: Float

    function draw() -> Void {
        print("drawing circle")
        return
    }

    function boundsX() -> Float {
        return 0.0 - radius
    }
}

function main() {
    let shape: Drawable = Circle(radius: 10.0)
    shape.draw()

    let x = shape.boundsX()
    if x == -10.0 {
        print("bounds x=-10.0")
    } else {
        print("bounds x=unexpected")
    }

    return
}
