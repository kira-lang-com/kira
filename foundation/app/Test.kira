struct TestResult {
    let name: String
    let passed: Bool
}

struct TestReport {
    let passed: Int
    let failed: Int
    let total: Int
}

enum TestStatus {
    Passed
    Failed
}

enum TestFailure {
    Runtime(String)
    Diagnostic(KiraError)
}

struct TestRuntime {
    function report(name: borrow String, passed: Bool) -> TestResult {
        return TestResult(name: name, passed: passed)
    }
}

comptime construct Test {
    sections {
        @Required
        function test -> Any
        
        @Required
        function expect -> Result<Any, TestFailure>
    }

    lifecycle {
        validate() {
            return;
        }
    }
}
