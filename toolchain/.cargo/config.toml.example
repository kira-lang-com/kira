# Cargo configuration example
# Copy this file to config.toml and adjust paths for your system

[env]
# Set the LLVM prefix path for your system
# macOS (Homebrew): LLVM_SYS_170_PREFIX = "/opt/homebrew/opt/llvm@17"
# Linux: LLVM_SYS_170_PREFIX = "/usr/lib/llvm-17"
# Or set via environment variable instead of this file
LLVM_SYS_170_PREFIX = "/path/to/llvm-17"
